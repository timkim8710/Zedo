<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zedo AI | Synthetic Knowledge</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="logo-container">
                <h1>Zedo<span>.ai</span></h1>
            </div>

            <div class="sidebar-content">
                <div class="section">
                    <p class="section-label">Input</p>
                    <label for="fileInput" class="import-card">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                        <span>Import .txt Note</span>
                        <input type="file" id="fileInput" accept=".txt">
                    </label>
                </div>

                <div class="section">
                    <p class="section-label">Learned Base</p>
                    <ul id="notesList" class="notes-stack">
                        </ul>
                </div>
            </div>
        </aside>

        <main class="workspace">
            <header class="workspace-header">
                <div class="engine-status">
                    <div class="pulse-dot"></div>
                    <span>Gemini 1.5 Flash Active</span>
                </div>
            </header>

            <div id="chatDisplay" class="chat-viewport">
                <div class="msg system">System online. Upload a note to begin contextual analysis.</div>
            </div>

            <div class="input-zone">
                <div class="command-bar">
                    <button class="bar-icon" title="Voice">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/><path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/></svg>
                    </button>

                    <input type="text" id="userInput" placeholder="Ask Zedo about your notes..." autocomplete="off">

                    <button id="clearBtn" class="bar-icon" title="Clear">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>

                    <button id="sendBtn" class="send-pill">
                        <span>Send</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path></svg>
                    </button>
                </div>
            </div>
        </main>
    </div>

    <script type="module" src="app.js"></script>
</body>
</html>
