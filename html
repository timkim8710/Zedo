<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zedo AI | Smart Notes</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="app-wrapper">
        <aside class="sidebar">
            <div class="brand">
                <h1>Zedo<span>.ai</span></h1>
            </div>

            <div class="upload-box">
                <p>Import Knowledge</p>
                <label for="fileInput" class="upload-btn">
                    <span>+ Upload .txt</span>
                    <input type="file" id="fileInput" accept=".txt">
                </label>
            </div>

            <div class="library">
                <h3>Learned Notes</h3>
                <ul id="notesList">
                    </ul>
            </div>
        </aside>

        <main class="chat-container">
            <header class="chat-header">
                <h2>AI Intelligence</h2>
                <div class="status-dot"></div>
            </header>

            <div id="chatDisplay" class="chat-display">
                <div class="message system">Zedo is ready. Upload your notes to begin.</div>
            </div>

            <div class="chat-input-area">
                <input type="text" id="userInput" placeholder="Ask Zedo about your notes..." autocomplete="off">
                <button id="sendBtn">
                    <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path></svg>
                </button>
            </div>
        </main>
    </div>

    <script type="module" src="app.js"></script>
</body>
</html>
