<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zedo AI | Your Intelligent Notebook</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="logo">
                <h1>Zedo<span>.ai</span></h1>
            </div>
            
            <div class="import-section">
                <h3>Import Note</h3>
                <label class="custom-file-upload">
                    <input type="file" id="fileInput" accept=".txt" />
                    Choose .txt File
                </label>
                <p id="uploadStatus"></p>
            </div>

            <div class="notes-list-container">
                <h3>My Knowledge Base</h3>
                <ul id="notesList"></ul>
            </div>
        </aside>

        <main class="chat-area">
            <div id="chatDisplay" class="chat-display">
                <div class="message system">Welcome to Zedo. Upload a note and ask me anything!</div>
            </div>

            <div class="input-container">
                <input type="text" id="userInput" placeholder="Ask Zedo about your notes..." />
                <button id="sendBtn">Ask</button>
            </div>
        </main>
    </div>

    <script type="module" src="app.js"></script>
</body>
</html>
